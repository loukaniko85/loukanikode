# Local Llama.cpp Configuration
# Use this if you have a local llama.cpp server running

# Server URL (http://host:port/v1 for OpenAI-compatible endpoint)
LLAMA_CPP_SERVER=http://10.0.24.200:8080/v1

# Model file name (optional - will be extracted from server response)
LLAMA_CPP_MODEL=GLM-4.7-Flash-UD-Q4_K_XL.gguf

# Optional: Explicitly enable llama mode (can be removed, but recommended for clarity)
LOUKANIKODE_USE_LLAMA=1

# Optional: API key for llama server (if your server requires authentication)
# LLAMA_API_KEY=your-api-key-here

# Optional: Custom timeout in milliseconds
# LLAMA_TIMEOUT_MS=30000

# Optional: Disable attribution header for better KV cache hit rates with local models
LOUKANIKODE_ATTRIBUTION_HEADER=0

# Optional: Disable telemetry
LOUKANIKODE_ENABLE_TELEMETRY=0
